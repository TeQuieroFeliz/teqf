rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read access for all images
    match /{allPaths=**} {
      allow read: if true;
    }

    // Articles folder — public read (covered by catch-all above); authenticated write.
    // getAdminUids() does not exist in Storage Rules — role-based restriction is
    // enforced at the Firestore level and in the server action, not here.
    match /articles/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // General images folder - allow authenticated users
    match /images/{fileName} {
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Portfolio images — no size limit, authenticated users only
    match /portfolio/{projectId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // User profiles/avatars
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;
    }

    // Furniture catalog images — public read, authenticated write
    match /furniture/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Flower catalog images — public read, authenticated write
    match /flowers/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Inventario TeQF item photos — public read, authenticated write
    match /inventory/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Planner event documents (regulations, layouts) — authenticated only
    match /planner-events/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Planner profile avatars — authenticated only
    match /planner-avatars/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Cash control receipts and proof photos (area-planner system)
    match /cash-control/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // TeQF Cash Control photo uploads
    match /cashcontrol/{allPaths=**} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Weddings section ──────────────────────────────────────────────────────

    // Read: any authenticated user
    match /weddings/{weddingId}/{allPaths=**} {
      allow read: if request.auth != null;
    }

    // Quotes (PDF only, max 20 MB) — TeQF + both + SuperAdmin
    match /weddings/{weddingId}/quotes/{fileName} {
      allow write: if request.auth != null
        && (request.auth.token.team == 'TeQF'
            || request.auth.token.team == 'both'
            || request.auth.token.role == 'superadmin')
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf');
      allow delete: if request.auth != null
        && (request.auth.token.team == 'TeQF'
            || request.auth.token.team == 'both'
            || request.auth.token.role == 'superadmin');
    }

    // Wedding-level Moodboard (PDF + image, max 20 MB) — XB + both + SuperAdmin.
    // Unique per wedding (not per function).
    match /weddings/{weddingId}/moodboard/{fileName} {
      allow write: if request.auth != null
        && (request.auth.token.team == 'XB'
            || request.auth.token.team == 'both'
            || request.auth.token.role == 'superadmin')
        && request.resource.size < 20 * 1024 * 1024
        && (request.resource.contentType.matches('application/pdf')
            || request.resource.contentType.matches('image/.*'));
      allow delete: if request.auth != null
        && (request.auth.token.team == 'XB'
            || request.auth.token.team == 'both'
            || request.auth.token.role == 'superadmin');
    }

    // Layouts + Moodboard (PDF + image, max 20 MB) — XB + both + SuperAdmin
    match /weddings/{weddingId}/functions/{functionId}/layouts/{fileName} {
      allow write: if request.auth != null
        && (request.auth.token.team == 'XB'
            || request.auth.token.team == 'both'
            || request.auth.token.role == 'superadmin')
        && request.resource.size < 20 * 1024 * 1024
        && (request.resource.contentType.matches('application/pdf')
            || request.resource.contentType.matches('image/.*'));
      allow delete: if request.auth != null
        && (request.auth.token.team == 'XB'
            || request.auth.token.team == 'both'
            || request.auth.token.role == 'superadmin');
    }

    match /weddings/{weddingId}/functions/{functionId}/moodboard/{fileName} {
      allow write: if request.auth != null
        && (request.auth.token.team == 'XB'
            || request.auth.token.team == 'both'
            || request.auth.token.role == 'superadmin')
        && request.resource.size < 20 * 1024 * 1024
        && (request.resource.contentType.matches('application/pdf')
            || request.resource.contentType.matches('image/.*'));
      allow delete: if request.auth != null
        && (request.auth.token.team == 'XB'
            || request.auth.token.team == 'both'
            || request.auth.token.role == 'superadmin');
    }

    // Inspiration photos (image only, max 10 MB) — XB + both + SuperAdmin
    match /weddings/{weddingId}/functions/{functionId}/inspiration/{fileName} {
      allow write: if request.auth != null
        && (request.auth.token.team == 'XB'
            || request.auth.token.team == 'both'
            || request.auth.token.role == 'superadmin')
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && (request.auth.token.team == 'XB'
            || request.auth.token.team == 'both'
            || request.auth.token.role == 'superadmin');
    }

    // Custom item images (image only, max 10 MB) — XB + both + SuperAdmin
    match /weddings/{weddingId}/functions/{functionId}/custom-items/{itemId}/{fileName} {
      allow write: if request.auth != null
        && (request.auth.token.team == 'XB'
            || request.auth.token.team == 'both'
            || request.auth.token.role == 'superadmin')
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && (request.auth.token.team == 'XB'
            || request.auth.token.team == 'both'
            || request.auth.token.role == 'superadmin');
    }
  }
}
