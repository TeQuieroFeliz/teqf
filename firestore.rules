rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin users — only server-side admin SDK writes, clients read their own
    match /admins/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Cash Control — any authenticated user
    match /cashControlProfiles/{doc} {
      allow read, write: if request.auth != null;
    }
    match /cashControlEvents/{doc} {
      allow read, write: if request.auth != null;
    }
    match /cashControlAssignments/{doc} {
      allow read, write: if request.auth != null;
    }
    match /cashControlMoneyReceived/{doc} {
      allow read, write: if request.auth != null;
    }
    match /cashControlExpenses/{doc} {
      allow read, write: if request.auth != null;
    }
    match /cashControlClosures/{doc} {
      allow read, write: if request.auth != null;
    }
    match /cashControlAudit/{doc} {
      allow read, write: if request.auth != null;
    }

    // All other collections — authenticated access
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
