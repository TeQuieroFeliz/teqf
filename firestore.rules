rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Permission helpers ────────────────────────────────────────────────────

    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isActiveAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && adminDoc().data.active == true;
    }

    function isSuperAdmin() {
      return isActiveAdmin() && adminDoc().data.role == 'superadmin';
    }

    function canView(section) {
      return isSuperAdmin()
        || (isActiveAdmin()
            && adminDoc().data.permissions[section] in ['view', 'editor']);
    }

    function canEdit(section) {
      return isSuperAdmin()
        || (isActiveAdmin()
            && adminDoc().data.permissions[section] == 'editor');
    }

    // Legacy alias
    function isAdmin() {
      return isActiveAdmin();
    }

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // BUG-11 fix: null-safe helper — plannerData().get() returns default if field
    // absent, so users without a /planners/{uid} doc don't cause a reads error.
    function plannerTeams() {
      return exists(/databases/$(database)/documents/planners/$(request.auth.uid))
        ? get(/databases/$(database)/documents/planners/$(request.auth.uid)).data.get('team', [])
        : [];
    }

    function hasTeam(teamName) {
      return isAuth() && teamName in plannerTeams();
    }

    function hasAnyTeam() {
      return isAuth() && plannerTeams().size() > 0;
    }

    // /users/{uid} — own document or admin
    match /users/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // /admins/{uid} — BUG-02 fix: only the owner or superadmin can read own doc;
    // client writes are blocked except lastLogin field by owner.
    match /admins/{uid} {
      allow read:   if isOwner(uid) || isSuperAdmin();
      allow create, delete: if false;
      // BUG-02 fix: allow owner to update only lastLogin (for client-side fallback).
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLogin']);
    }

    // /articles/* — public read; 'view' to read privately, 'editor' to write.
    match /articles/{id} {
      allow read: if true;
      allow write: if canEdit('blog');
    }

    // /furnitureItems/* and /furnitureMeta/* — public read, editor to write.
    match /furnitureItems/{id} {
      allow read: if true;
      allow write: if canEdit('furniture');
    }
    match /furnitureMeta/{id} {
      allow read: if true;
      allow write: if canEdit('furniture');
    }

    // /floralInspiration/* — public read, editor to write.
    match /floralInspiration/{id} {
      allow read: if true;
      allow write: if canEdit('florals');
    }

    // /portfolioProjects/* — public read, editor to write.
    match /portfolioProjects/{id} {
      allow read: if true;
      allow write: if canEdit('portfolio');
    }

    // /planners/{docId} — readable by the planner (email match) or any active admin.
    match /planners/{docId} {
      allow read:  if isOwner(docId) || isAdmin()
        || (isAuth() && resource.data.email == request.auth.token.email);
      allow write: if isOwner(docId) || isAdmin();
    }

    // /plannerRequests/* — write-only for anonymous; admin can read all;
    // authenticated users can read their own request.
    match /plannerRequests/{id} {
      allow read:   if isAdmin() || isOwner(id);
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // /events/{eventId} — owner or someone with at least view on events.
    match /events/{eventId} {
      allow read:   if isOwner(resource.data.userId) || canView('events');
      allow create: if isOwner(request.resource.data.userId) || canEdit('events');
      allow update, delete: if isOwner(resource.data.userId) || canEdit('events');
    }

    // /plannerEvents/{eventId} — BUG-06 fix: XB team members can create and read
    // their own events; TeQF team members can read all events.
    match /plannerEvents/{eventId} {
      allow read:   if isOwner(resource.data.plannerId) || canView('projects')
        || hasTeam('TeQF');
      allow create: if isOwner(request.resource.data.plannerId) || canEdit('projects')
        || (isOwner(request.resource.data.plannerId) && hasTeam('XB'));
      allow update, delete: if isOwner(resource.data.plannerId) || canEdit('projects');

      // /plannerEvents/{eventId}/expenses/{expenseId}
      match /expenses/{expenseId} {
        allow read: if
          isOwner(get(/databases/$(database)/documents/plannerEvents/$(eventId)).data.plannerId)
          || canView('projects')
          || hasTeam('TeQF');
        allow write: if
          isOwner(get(/databases/$(database)/documents/plannerEvents/$(eventId)).data.plannerId)
          || canEdit('projects')
          || (isOwner(get(/databases/$(database)/documents/plannerEvents/$(eventId)).data.plannerId) && hasTeam('XB'));
      }
    }

    // /teqfProjects — TeQF team members or admin.
    match /teqfProjects/{projectId} {
      allow read, write: if hasTeam('TeQF') || isSuperAdmin();

      match /cashControl/{docId} {
        allow read, write: if hasTeam('TeQF') || isSuperAdmin();
      }

      match /orarioDiLavoro/{docId} {
        allow read, write: if hasTeam('TeQF') || isSuperAdmin();
      }
    }

    // BUG-01 fix: Cash Control collections restricted to TeQF team or SuperAdmin.
    // cashControlAudit is append-only for TeQF; only SuperAdmin can read audit log.
    match /cashControlProfiles/{doc} {
      allow read, write: if hasTeam('TeQF') || isSuperAdmin();
    }
    match /cashControlEvents/{doc} {
      allow read, write: if hasTeam('TeQF') || isSuperAdmin();
    }
    match /cashControlAssignments/{doc} {
      allow read, write: if hasTeam('TeQF') || isSuperAdmin();
    }
    match /cashControlMoneyReceived/{doc} {
      allow read, write: if hasTeam('TeQF') || isSuperAdmin();
    }
    match /cashControlExpenses/{doc} {
      allow read, write: if hasTeam('TeQF') || isSuperAdmin();
    }
    match /cashControlClosures/{doc} {
      allow read, write: if hasTeam('TeQF') || isSuperAdmin();
    }
    match /cashControlAudit/{doc} {
      // Append-only for TeQF; only SuperAdmin can read the audit log.
      allow read:   if isSuperAdmin();
      allow create: if hasTeam('TeQF') || isSuperAdmin();
      allow update, delete: if false;
    }

  }
}
