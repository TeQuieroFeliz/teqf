rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin helpers ──────────────────────────────────────────────────────────

    function isSignedIn() { return request.auth != null; }

    // isAuth — legacy alias kept so existing rules that reference it still compile.
    function isAuth() { return isSignedIn(); }

    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isActiveAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && adminDoc().data.active == true;
    }

    // isAdmin — any active admin record (superadmin / team / planner roles).
    function isAdmin() { return isActiveAdmin(); }

    function isSuperAdmin() {
      return isActiveAdmin() && adminDoc().data.role == 'superadmin';
    }

    // Section-level permissions for admin users.
    function canView(section) {
      return isSuperAdmin()
        || (isActiveAdmin()
            && adminDoc().data.permissions[section] in ['view', 'editor']);
    }
    function canEdit(section) {
      return isSuperAdmin()
        || (isActiveAdmin()
            && adminDoc().data.permissions[section] == 'editor');
    }

    // ── Planner helpers ────────────────────────────────────────────────────────

    // Guard: does a /planners/{uid} doc exist for the signed-in user?
    function plannerExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/planners/$(request.auth.uid));
    }

    // Returns the planner document's data. Only call after plannerExists() == true
    // (i.e., inside a context where isApproved() or inTeam() already passed).
    // Firestore caches get() per path within one rule evaluation, so multiple calls
    // within the same expression cost only one read.
    function plannerDocData() {
      return get(/databases/$(database)/documents/planners/$(request.auth.uid)).data;
    }

    // isApproved — Opzione A confirmed by user:
    //   active == true is the primary gate.
    //   status absent (legacy docs created via addPlanner without a request) → passes,
    //   because get('status','') returns '' and '' != 'pending'/'rejected' is true.
    //   status == 'approved' also passes. pending/rejected are explicitly blocked.
    function isApproved() {
      return plannerExists()
        && plannerDocData().active == true
        && plannerDocData().get('status', '') != 'pending'
        && plannerDocData().get('status', '') != 'rejected';
    }

    // inTeam — team[] values are exactly 'XB' and 'TeQF' (uppercase).
    // .get('team',[]) is null-safe: absent field returns [] so 't in []' == false.
    function inTeam(t) {
      return isApproved()
        && t in plannerDocData().get('team', []);
    }

    // ── /users/{uid} ───────────────────────────────────────────────────────────
    // FIX-A: owner can update innocuous profile fields only — role/status/approved
    // are write-protected for the owner; only isAdmin() can touch those.
    // All legitimate user creates/deletes go through Admin SDK (server actions),
    // so client create/delete is admin-only.
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update:
        if isAdmin()
        || (isOwner(uid)
            && !request.resource.data.diff(resource.data)
                .affectedKeys().hasAny(['role', 'status', 'approved']));
    }

    // ── /admins/{uid} ─────────────────────────────────────────────────────────
    // Unchanged: only the owner or a superadmin can read; client writes blocked
    // except for lastLogin (client-side fallback for the auth context).
    match /admins/{uid} {
      allow read:           if isOwner(uid) || isSuperAdmin();
      allow create, delete: if false;
      allow update:
        if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLogin']);
    }

    // ── Public catalog and content ─────────────────────────────────────────────
    match /articles/{id} {
      allow read:  if true;
      allow write: if canEdit('blog');
    }
    match /furnitureItems/{id} {
      allow read:  if true;
      allow write: if canEdit('furniture');
    }
    match /furnitureMeta/{id} {
      allow read:  if true;
      allow write: if canEdit('furniture');
    }
    match /floralInspiration/{id} {
      allow read:  if true;
      allow write: if canEdit('florals');
    }
    match /portfolioProjects/{id} {
      allow read:  if true;
      allow write: if canEdit('portfolio');
    }

    // ── /planners/{docId} ─────────────────────────────────────────────────────
    // READ: the planner (isOwner) OR any active admin OR same-email match
    //       (the email check covers the legacy getDocs-by-email path in
    //       PlannerAuthContext when the uid-keyed doc is absent).
    // FIX-B: WRITE is now admin-only.
    //   Confirmed: ALL client-side planner writes (team, active, teamRole,
    //   lastLogin, avatarUrl, mustChangePassword) go through server actions with
    //   Admin SDK, which bypass these rules. No legitimate client write exists.
    //   This closes the self-escalation vector (a user writing team/active themselves).
    match /planners/{docId} {
      allow read:  if isOwner(docId) || isAdmin()
        || (isSignedIn() && resource.data.email == request.auth.token.email);
      allow write: if isAdmin();
    }

    // ── /plannerRequests/{id} ─────────────────────────────────────────────────
    // FIX-C: create now requires authentication (was `if true`).
    // Note: the registration server action uses Admin SDK, so this rule
    // is a client-SDK safety net only.
    match /plannerRequests/{id} {
      allow read:           if isAdmin() || isOwner(id);
      allow create:         if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── /events/{eventId} ─────────────────────────────────────────────────────
    // Unchanged: owner or admin with events permission.
    match /events/{eventId} {
      allow read:           if isOwner(resource.data.userId) || canView('events');
      allow create:         if isOwner(request.resource.data.userId) || canEdit('events');
      allow update, delete: if isOwner(resource.data.userId) || canEdit('events');
    }

    // ── /plannerEvents/{eventId} ──────────────────────────────────────────────
    // Replaced hasTeam() with inTeam() (adds isApproved() check).
    match /plannerEvents/{eventId} {
      allow read:           if inTeam('XB') || inTeam('TeQF') || canView('projects');
      allow create:         if inTeam('XB') || canEdit('projects');
      allow update, delete: if inTeam('XB') || canEdit('projects');

      match /expenses/{expenseId} {
        allow read:
          if isOwner(get(/databases/$(database)/documents/plannerEvents/$(eventId)).data.plannerId)
          || canView('projects')
          || inTeam('TeQF');
        allow write:
          if isOwner(get(/databases/$(database)/documents/plannerEvents/$(eventId)).data.plannerId)
          || canEdit('projects')
          || (inTeam('XB')
              && isOwner(get(/databases/$(database)/documents/plannerEvents/$(eventId)).data.plannerId));
      }
    }

    // ── /teqfProjects/{projectId} ─────────────────────────────────────────────
    // FIX-D: cashControl subcollection blocks create/update/delete when the parent
    // project has isClosed == true, unless the caller isAdmin().
    // isClosed is a boolean on the teqfProjects document (set by the teqf-close API
    // route via Admin SDK); absent field defaults to false via .get('isClosed', false).
    match /teqfProjects/{projectId} {
      allow read:           if inTeam('TeQF') || isAdmin();
      allow create:         if inTeam('TeQF') || isAdmin();
      allow update, delete: if inTeam('TeQF') || isAdmin();

      // cashControl movements: blocked when project is closed (unless admin).
      match /cashControl/{docId} {
        allow read: if inTeam('TeQF') || isAdmin();

        // Helpers to avoid repeating the parent-doc get().
        // isClosed check: get() is cached per path, so this costs 1 extra read.
        allow create:
          if isAdmin()
          || (inTeam('TeQF')
              && get(/databases/$(database)/documents/teqfProjects/$(projectId))
                  .data.get('isClosed', false) != true);

        allow update, delete:
          if isAdmin()
          || (inTeam('TeQF')
              && get(/databases/$(database)/documents/teqfProjects/$(projectId))
                  .data.get('isClosed', false) != true);
      }

      match /orarioDiLavoro/{docId} {
        allow read, write: if inTeam('TeQF') || isAdmin();
      }
    }

    // ── Legacy Cash Control collections (area-planner system) ─────────────────
    // Unchanged semantics; replaced isSuperAdmin() with isAdmin() for consistency.
    match /cashControlProfiles/{doc} {
      allow read, write: if inTeam('TeQF') || isAdmin();
    }
    match /cashControlEvents/{doc} {
      allow read, write: if inTeam('TeQF') || isAdmin();
    }
    match /cashControlAssignments/{doc} {
      allow read, write: if inTeam('TeQF') || isAdmin();
    }
    match /cashControlMoneyReceived/{doc} {
      allow read, write: if inTeam('TeQF') || isAdmin();
    }
    match /cashControlExpenses/{doc} {
      allow read, write: if inTeam('TeQF') || isAdmin();
    }
    match /cashControlClosures/{doc} {
      allow read, write: if inTeam('TeQF') || isAdmin();
    }
    match /cashControlAudit/{doc} {
      // Append-only for TeQF team; only superadmin can read the audit log.
      allow read:           if isSuperAdmin();
      allow create:         if inTeam('TeQF') || isAdmin();
      allow update, delete: if false;
    }

  }
}
